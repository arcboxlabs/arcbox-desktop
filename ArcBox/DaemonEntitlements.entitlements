<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Virtualization.framework access (required for VMs on macOS) -->
    <key>com.apple.security.virtualization</key>
    <true/>

    <!-- Hypervisor access (low-level VM control) -->
    <key>com.apple.security.hypervisor</key>
    <true/>

    <!-- VM networking (required for VZNATNetworkDeviceAttachment / vmnet bridge) -->
    <key>com.apple.vm.networking</key>
    <true/>

    <!-- Network access for container networking (DNS, DHCP, Docker socket) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
